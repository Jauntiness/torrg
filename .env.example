# Copy to .env and fill in. .env is gitignored.

# TorBox API key (Settings -> API on torbox.app). Required.
TORBOX_API_KEY=your-torbox-api-key

# Native-TorBox-WebDAV fallback creds, used only for files whose fast CDN URL
# stalls (the "CatBox" pattern). Optional but recommended. From your TorBox
# account's WebDAV settings.
TORBOX_WEBDAV_USER=
TORBOX_WEBDAV_PASS=
